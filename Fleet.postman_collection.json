              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/fleet",
          "host": ["{{baseUrl}}"],
          "path": ["api", "fleet"]
        },
        "description": "Creates a new fleet entry.\nAttach a real image file (jpg/png) to **Image** and a real 3D model file (glb/gltf/obj) to **Model3D**.\nThe new fleet `id` is automatically saved to the `fleetId` variable for the next requests."
      }
    },

    {
      "name": "2 – Fleet: Get All (GET)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "",
              "var body = pm.response.json();",
              "pm.test('Response is an array', function () { pm.expect(body).to.be.an('array'); });",
              "pm.test('Array has at least one fleet', function () { pm.expect(body.length).to.be.above(0); });",
              "",
              "// Validate shape of the first fleet object",
              "var first = body[0];",
              "pm.test('Fleet has id', function () { pm.expect(first).to.have.property('id'); });",
              "pm.test('Fleet has nameEn', function () { pm.expect(first).to.have.property('nameEn'); });",
              "pm.test('Fleet has nameAr', function () { pm.expect(first).to.have.property('nameAr'); });",
              "pm.test('Fleet has imageUrl', function () { pm.expect(first).to.have.property('imageUrl'); });",
              "pm.test('Fleet has model3DUrl', function () { pm.expect(first).to.have.property('model3DUrl'); });",
              "pm.test('Fleet has features array', function () { pm.expect(first.features).to.be.an('array'); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/fleet",
          "host": ["{{baseUrl}}"],
          "path": ["api", "fleet"]
        },
        "description": "Returns all fleet entries including their features. No auth required."
      }
    },

    {
      "name": "3 – Fleet: Get By Id (GET)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "",
              "var body = pm.response.json();",
              "pm.test('Returned fleet id matches requested id', function () {",
              "  pm.expect(body.id).to.equal(parseInt(pm.collectionVariables.get('fleetId')));",
              "});",
              "pm.test('Has nameEn', function () { pm.expect(body.nameEn).to.be.a('string').and.not.empty; });",
              "pm.test('Has imageUrl', function () { pm.expect(body.imageUrl).to.be.a('string'); });",
              "pm.test('Has model3DUrl', function () { pm.expect(body.model3DUrl).to.be.a('string'); });",
              "pm.test('Features is an array', function () { pm.expect(body.features).to.be.an('array'); });",
              "pm.test('Has 3 features', function () { pm.expect(body.features.length).to.equal(3); });",
              "",
              "// Validate feature shape",
              "if (body.features.length > 0) {",
              "  var f = body.features[0];",
              "  pm.test('Feature has titleEn', function () { pm.expect(f).to.have.property('titleEn'); });",
              "  pm.test('Feature has titleAr', function () { pm.expect(f).to.have.property('titleAr'); });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/fleet/{{fleetId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "fleet", "{{fleetId}}"]
        },
        "description": "Returns a single fleet by id (uses the `fleetId` variable set by the Create request)."
      }
    },

