{
  "info": {
    "_postman_id": "fleet-api-collection",
    "name": "Merkwave – Fleet API",
    "description": "Full test suite for the Fleet controller.\n\nWorkflow:\n1. Run **Login** first — the JWT token is stored automatically in the `token` variable.\n2. Run the remaining requests in order (Create → Get All → Get By Id → Update → Delete).\n\nVariables:\n- `baseUrl`  — API root (default: http://localhost:5070)\n- `token`    — populated automatically by the Login request\n- `fleetId`  — populated automatically by the Create request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:5070", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" },
    { "key": "fleetId",  "value": "1",                     "type": "string" }
  ],

  "item": [

    {
      "name": "0 – Auth: Login (get JWT token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "",
              "var body = pm.response.json();",
              "pm.test('Response contains token', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });",
              "",
              "// Store the token so all protected requests can use it automatically",
              "pm.collectionVariables.set('token', body.token);",
              "console.log('JWT token saved:', body.token.substring(0, 30) + '...');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"1?BMP\\\"1vv?7\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Authenticates and stores the JWT in the `token` collection variable. Run this before any [Authorize] endpoint."
      }
    },

    {
      "name": "1 – Fleet: Create (POST) – with image + 3D model",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "",
              "var body = pm.response.json();",
              "pm.test('Response has id', function () { pm.expect(body.id).to.be.a('number').and.above(0); });",
              "pm.test('Success message present', function () { pm.expect(body.message).to.include('created'); });",
              "",
              "// Save the new fleet id for subsequent requests",
              "pm.collectionVariables.set('fleetId', body.id);",
              "console.log('Created fleet id:', body.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "NameEn",
              "value": "Merkwave Vessel Alpha",
              "type": "text",
              "description": "English name of the fleet unit"
            },
            {
              "key": "NameAr",
              "value": "سفينة ميركويف ألفا",
              "type": "text",
              "description": "Arabic name of the fleet unit"
            },
            {
              "key": "DescriptionEn",
              "value": "A state-of-the-art offshore support vessel designed for deep-water operations.",
              "type": "text"
            },
            {
